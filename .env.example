# ============================================================
# Django + django-ninja 项目环境变量配置
# ============================================================
# 使用说明：
# 1. 复制本文件为 .env
# 2. 根据环境修改对应配置
# 3. 敏感信息（密钥、密码等）不要提交到 Git
# ============================================================

# ========== 第一部分：Django 核心配置 ==========

# Django 加密密钥（必须修改！）
# 生产环境建议使用：python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())" 生成
DJANGO_SECRET_KEY=change-me-in-production

# 调试模式（开发=True，生产=False）
# 开发时 = True能看到详细错误信息
# 生产时 = False隐藏错误信息，防止被黑客利用
DJANGO_DEBUG=True

# 允许访问的域名/IP（仅填写真实域名，开发环境可保持默认）
# 只有列表中的地址能访问你的网站，防止DNS重新绑定攻击
# 多个域名用逗号分隔，例如：localhost,127.0.0.1,example.com,www.example.com
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# ========== 第二部分：CORS 跨域配置 ==========

# CORS 允许的前端来源（解决前后端分离时的跨域问题）
# 格式： http://域名:端口
# 多个域名用逗号分隔
# 例如： http://localhost:3000,http://127.0.0.1:3000
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173,http://127.0.0.1:5173

# 是否允许所有来源（仅开发环境使用）
# 设置为 True 表示允许任何域名访问，生产环境禁止开启
# CORS_ALLOW_ALL_ORIGINS=False

# ========== 第三部分：数据库配置 ==========

# 数据库连接 URL（推荐方式，零配置即可运行）
# SQLite（默认，开发用）：sqlite:///db.sqlite3
DATABASE_URL=sqlite:///db.sqlite3

# --- PostgreSQL 配置示例 ---
# 安装依赖：pip install psycopg2-binary
# 格式：postgres://用户名:密码@主机:端口/数据库名
# DATABASE_URL=postgres://myuser:mypassword@localhost:5432/mydb
# 或使用单独配置（不推荐，已废弃）：
# DB_ENGINE=django.db.backends.postgresql
# DB_NAME=mydb
# DB_USER=myuser
# DB_PASSWORD=mypassword
# DB_HOST=localhost
# DB_PORT=5432

# --- MySQL 配置示例 ---
# 安装依赖：pip install mysqlclient
# 格式：mysql://用户名:密码@主机:端口/数据库名
# DATABASE_URL=mysql://myuser:mypassword@localhost:3306/mydb?charset=utf8mb4
# 或使用单独配置（不推荐，已废弃）：
# DB_ENGINE=django.db.backends.mysql
# DB_NAME=mydb
# DB_USER=myuser
# DB_PASSWORD=mypassword
# DB_HOST=localhost
# DB_PORT=3306

# 数据库连接最大存活时间（秒），生产环境建议设置
# DATABASE_CONN_MAX_AGE=600

# ========== 第四部分：OSS 对象存储配置 ==========

# 用于存储静态文件和媒体文件（适合生产环境）
# 支持阿里云 OSS、AWS S3、其他 S3 兼容存储

# 是否启用 OSS（True=启用，False=使用本地存储）
USE_OSS=False

# OSS 服务地址（不同厂商不同 endpoint）
# 阿里云 OSS：https://help.aliyun.com/document_detail/31837.html
# AWS S3：https://docs.aws.amazon.com/general/latest/gr/s3.html
# 格式：https://oss-cn-hangzhou.aliyuncs.com
OSS_ENDPOINT=https://oss-cn-hangzhou.aliyuncs.com

# OSS Access Key ID（访问密钥 ID）
OSS_ACCESS_KEY_ID=your-access-key-id

# OSS Access Key Secret（访问密钥密码）
OSS_ACCESS_KEY_SECRET=your-access-key-secret

# OSS Bucket 名称
OSS_BUCKET_NAME=my-bucket

# OSS Bucket 所在区域
OSS_REGION=cn-hangzhou

# 是否开启 HTTPS
OSS_SECURE=True

# 访问文件的 URL 前缀
# 如果使用 CDN，请填写 CDN 域名
# OSS 默认格式：https://my-bucket.oss-cn-hangzhou.aliyuncs.com
OSS_BASE_URL=https://my-bucket.oss-cn-hangzhou.aliyuncs.com

# 上传文件的最大大小（字节），默认 10MB
# OSS_MAX_FILE_SIZE=10485760

# 允许的文件扩展名（用逗号分隔）
# OSS_ALLOWED_EXTENSIONS=jpg,jpeg,png,gif,mp4,mp3,pdf

# --- S3 兼容存储配置（AWS、MinIO、腾讯云 COS 等）---
# 如果使用 S3 兼容存储，取消下面注释
# S3_ENDPOINT_URL=https://s3.amazonaws.com
# S3_ACCESS_KEY=your-s3-access-key
# S3_SECRET_KEY=your-s3-secret-key
# S3_BUCKET_NAME=my-s3-bucket
# S3_REGION=us-east-1

# ========== 第五部分：国际化和时区 ==========

# 网站语言
# 可选值：zh-hans（简体中文）、en（英语）等
# LANGUAGE_CODE=zh-hans

# 时区
# 可选值：Asia/Shanghai（中国）、UTC（世界标准时间）等
# TIME_ZONE=Asia/Shanghai

# ========== 第六部分：静态文件和媒体文件 ==========

# 静态文件访问 URL（CSS、JS、图片等固定文件）
# 默认：/static/
# STATIC_URL=/static/

# 生产环境静态文件收集目录
# STATIC_ROOT=/path/to/staticfiles

# 媒体文件访问 URL（用户上传的文件）
# 默认：/media/
# MEDIA_URL=/media/

# 媒体文件存储目录（当 USE_OSS=False 时使用本地存储）
# MEDIA_ROOT=/path/to/media

# ========== 第七部分：安全配置（生产环境） ==========

# 强制 HTTPS（仅在反向代理已配置 HTTPS 时开启）
# SECURE_SSL_REDIRECT=True

# HTTPS 严格传输安全（HSTS）
# SECURE_HSTS_SECONDS=31536000
# SECURE_HSTS_INCLUDE_SUBDOMAINS=True
# SECURE_HSTS_PRELOAD=True

# CSRF Cookie 仅通过 HTTPS 发送
# CSRF_COOKIE_SECURE=True

# Session Cookie 仅通过 HTTPS 发送
# SESSION_COOKIE_SECURE=True

# ========== 第八部分：邮件配置（可选） ==========

# 用于发送邮件的 SMTP 服务器
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=your-email@gmail.com
# EMAIL_HOST_PASSWORD=your-app-password
# DEFAULT_FROM_EMAIL=Django App <noreply@example.com>

# ========== 第九部分：Redis 缓存配置（可选） ==========

# 用于缓存、Session 存储、实时功能等
# 安装依赖：pip install redis
# 安装 Django Redis 缓存后端：pip install django-redis
# REDIS_URL=redis://localhost:6379/0
# CACHES={"default": {"BACKEND": "django_redis.cache.RedisCache", "LOCATION": "redis://localhost:6379/1"}}

# ========== 第十部分：Ninja API 配置 ==========

# 分页每页数量
# NINJA_PAGINATION_PER_PAGE=20
